PORT=3001
NODE_ENV=development
DATABASE_URL=postgresql://USER:PASSWORD@HOST/opdds?sslmode=require
JWT_SECRET=change-me
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000,https://app.opoderdosdesacreditados.online,https://opoderdosdesacreditados.online
ADMIN_EMAIL=admin@opdds.local
ADMIN_PASSWORD=troque-esta-senha
ADMIN_NAME=Administrador OPDDS
APP_URL=http://127.0.0.1:5173
MAIL_FROM="O Poder dos Desacreditados <no-reply@opoderdosdesacreditados.online>"
# Resend: crie a chave em https://resend.com/api-keys e use uma destas opções:
# Opção simples: preencha só RESEND_API_KEY e mantenha MAIL_FROM com domínio verificado.
RESEND_API_KEY=
# Opção SMTP explícita:
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=resend
SMTP_PASS=
